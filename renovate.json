{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "timezone": "Europe/Prague",
  "tekton": {
    "automerge": true,
    "automergeStrategy": "rebase",
    "automergeType": "pr",
    "enabled": true,
    "ignoreTests": true,
    "platformAutomerge": true
  },
  "gomod": {
    "packageRules": [
      {
        "matchManagers": [
          "gomod"
        ],
        "matchDepTypes": [
          "indirect"
        ],
        "enabled": false
      }
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": ["https://github.com/reorg/pg_repack.git"],
      "enabled": false
    },
    {
      "matchManagers": [
        "gomod"
      ],
      "groupName": "go modules",
      "groupSlug": "go-modules"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "dockerfiles",
      "groupSlug": "dockerfiles"
    }
  ]
}
